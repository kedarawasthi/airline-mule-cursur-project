          }
        },
        {
          "name": "DW Complex - XML to JSON",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/xml"
              }
            ],
            "description": "Purpose: Transform nested XML payload into JSON shape.\\n\\nUse when: Testing more complex mapping logic for XML source messages.\\n\\ncURL:\\n\\ncurl --request POST '{{baseUrl}}/dw/complex' \\n--header 'Content-Type: application/xml' \\n--data-raw '<orders><order><id>1001</id><amount>120.5</amount></order></orders>'",
            "body": {
              "mode": "raw",
              "raw": "<orders>\n  <order>\n    <id>1001</id>\n    <amount>120.5</amount>\n  </order>\n  <order>\n    <id>1002</id>\n    <amount>45.0</amount>\n  </order>\n</orders>"
            },
            "url": {
              "raw": "{{baseUrl}}/dw/complex",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "dw",
                "complex"
              ]
            }
          }
        },
        {
          "name": "DW Multi Scenario 1 - JSON to XML",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Convert passenger JSON payload into structured XML output with baggage grouping.\\n\\nUse when: Validating conditional and array-based DataWeave logic.\\n\\ncURL:\\n\\ncurl --request POST '{{baseUrl}}/dw/multi1' \\n--header 'Content-Type: application/json' \\n--data-raw '{\"passengerName\":\"Jane Doe\",\"flightNumber\":\"AA450\",\"travelDate\":\"04/15/2026\"}'",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"passengerName\": \"Jane Doe\",\n  \"flightNumber\": \"AA450\",\n  \"travelDate\": \"04/15/2026\",\n  \"flightClass\": \"Business\",\n  \"baggage\": [\n    {\n      \"id\": \"BAG001\",\n      \"weight\": 22\n    },\n    {\n      \"id\": \"BAG002\",\n      \"weight\": 35\n    },\n    {\n      \"id\": \"BAG003\",\n      \"weight\": 28\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/dw/multi1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "dw",
                "multi1"
              ]
            }
          }
        },
        {
          "name": "DW Multi Scenario 2 - XML to JSON",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/xml"
              }
            ],
            "description": "Purpose: Convert flights XML payload into enriched JSON array and filter cancelled flights.\\n\\nUse when: Validating filtering + formatting transformations.\\n\\ncURL:\\n\\ncurl --request POST '{{baseUrl}}/dw/multi2' \\n--header 'Content-Type: application/xml' \\n--data-raw '<flights><flight><id>FL901</id></flight></flights>'",
            "body": {
              "mode": "raw",
              "raw": "<flights>\n  <flight>\n    <id>FL901</id>\n    <src>JFK</src>\n    <dest>LAX</dest>\n    <deptTime>2026-04-20T14:30</deptTime>\n    <price>650</price>\n    <status>ACTIVE</status>\n  </flight>\n  <flight>\n    <id>FL902</id>\n    <src>ORD</src>\n    <dest>MIA</dest>\n    <deptTime>2026-04-21T09:00</deptTime>\n    <price>380</price>\n    <status>CANCELLED</status>\n  </flight>\n</flights>"
            },
            "url": {
              "raw": "{{baseUrl}}/dw/multi2",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "dw",
                "multi2"
              ]
            }
          }
        }
