    {
      "name": "01 - Flights CRUD Services",
      "description": "Core business operations for flights resource.",
      "item": [
        {
          "name": "Create Flight (POST /api/flights)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Create a new flight record.\\n\\nUse when: Seeding or functional testing create path.\\n\\ncURL:\\n\\ncurl --request POST '{{baseUrl}}/api/flights' \\n--header 'Content-Type: application/json' \\n--data-raw '{\"ID\": 826683, \"code\":\"AA826683\", \"price\":321, \"departureDate\":\"2026-06-01T10:30:00Z\", \"origin\":\"CLE\", \"destination\":\"SFO\", \"emptySeats\":12, \"plane\":{\"type\":\"Boeing 737\", \"totalSeats\":180}}'",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ID\": 826683,\n  \"code\": \"AA826683\",\n  \"price\": 321,\n  \"departureDate\": \"2026-06-01T10:30:00Z\",\n  \"origin\": \"CLE\",\n  \"destination\": \"SFO\",\n  \"emptySeats\": 12,\n  \"plane\": {\n    \"type\": \"Boeing 737\",\n    \"totalSeats\": 180\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/flights",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "flights"
              ]
            }
          }
        },
        {
          "name": "Get Flight by ID (GET /api/flights/{ID})",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Retrieve one specific flight by ID.\\n\\nUse when: Verifying create/update persistence.\\n\\ncURL:\\n\\ncurl --request GET '{{baseUrl}}/api/flights/{{flightId}}' \\n--header 'Accept: application/json'",
            "url": {
              "raw": "{{baseUrl}}/api/flights/{{flightId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "flights",
                "{{flightId}}"
              ]
            }
          }
        },
        {
          "name": "Update Flight by ID (PUT /api/flights/{ID})",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Update mutable fields for an existing flight.\\n\\nUse when: Validating update logic and downstream notification trigger path.\\n\\ncURL:\\n\\ncurl --request PUT '{{baseUrl}}/api/flights/{{flightId}}' \\n--header 'Content-Type: application/json' \\n--data-raw '{\"code\":\"AA826683-UPDATED\", \"price\":333, \"departureDate\":\"2026-06-01T11:00:00Z\", \"origin\":\"CLE\", \"destination\":\"SFO\", \"emptySeats\":10, \"plane\":{\"type\":\"Boeing 737 MAX\", \"totalSeats\":180}}'",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"AA826683-UPDATED\",\n  \"price\": 333,\n  \"departureDate\": \"2026-06-01T11:00:00Z\",\n  \"origin\": \"CLE\",\n  \"destination\": \"SFO\",\n  \"emptySeats\": 10,\n  \"plane\": {\n    \"type\": \"Boeing 737 MAX\",\n    \"totalSeats\": 180\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/flights/{{flightId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "flights",
                "{{flightId}}"
