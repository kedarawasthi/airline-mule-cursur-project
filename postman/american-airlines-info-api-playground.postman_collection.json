          "name": "Open API Console (Interactive Docs)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "text/html"
              }
            ],
            "description": "Purpose: Open APIKit console documentation for the running app.\\n\\nUse when: You want to inspect resources and test from browser-like console.\\n\\ncURL:\\n\\ncurl --request GET '{{baseUrl}}/console/' \\n--header 'Accept: text/html'",
            "url": {
              "raw": "{{baseUrl}}/console/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "console",
                ""
              ]
            }
          }
        },
        {
          "name": "Smoke Check - Get All Flights",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Confirm API runtime is reachable and returning flight data.\\n\\nUse when: First request after import/deploy.\\n\\ncURL:\\n\\ncurl --request GET '{{baseUrl}}/api/flights' \\n--header 'Accept: application/json'",
            "url": {
              "raw": "{{baseUrl}}/api/flights",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "flights"
              ]
            }
          }
        },
        {
          "name": "Query Flights by Destination",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Retrieve flights filtered by destination (`CLE`, `SFO`, `LAX`).\\n\\nUse when: Validating query-based business filtering.\\n\\ncURL:\\n\\ncurl --request GET '{{baseUrl}}/api/flights?destination={{destination}}' \\n--header 'Accept: application/json'",
            "url": {
              "raw": "{{baseUrl}}/api/flights?destination={{destination}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "flights"
              ],
              "query": [
                {
                  "key": "destination",
                  "value": "{{destination}}"
                }
              ]
            }
          }
        }
      ]
