    {
      "name": "02 - Batch Processing Service",
      "description": "Bulk ingest/upsert workflow for flights.",
      "item": [
        {
          "name": "Batch Upsert Flights (POST /api/flights/batch)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Submit multiple flight records in one call for batch processing.\\n\\nUse when: Validating batch path, partial failure behavior, and summary response.\\n\\ncURL:\\n\\ncurl --request POST '{{baseUrl}}/api/flights/batch' \\n--header 'Content-Type: application/json' \\n--data-raw '[{\"ID\":901001,\"code\":\"AA901001\",\"price\":410,\"departureDate\":\"2026-04-10T08:00:00Z\",\"origin\":\"SFO\",\"destination\":\"LAX\",\"emptySeats\":22,\"plane\":{\"type\":\"Boeing 737\",\"totalSeats\":180}}]'",
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"ID\": 901001,\n    \"code\": \"AA901001\",\n    \"price\": 410,\n    \"departureDate\": \"2026-04-10T08:00:00Z\",\n    \"origin\": \"SFO\",\n    \"destination\": \"LAX\",\n    \"emptySeats\": 22,\n    \"plane\": {\n      \"type\": \"Boeing 737\",\n      \"totalSeats\": 180\n    }\n  },\n  {\n    \"ID\": 901002,\n    \"code\": \"AA901002\",\n    \"price\": 520,\n    \"departureDate\": \"2026-04-10T09:30:00Z\",\n    \"origin\": \"CLE\",\n    \"destination\": \"SFO\",\n    \"emptySeats\": 18,\n    \"plane\": {\n      \"type\": \"Airbus A320\",\n      \"totalSeats\": 160\n    }\n  }\n]"
            },
            "url": {
              "raw": "{{baseUrl}}/api/flights/batch",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "flights",
                "batch"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "03 - DataWeave Demo Services",
      "description": "Standalone DataWeave transformation endpoints for demo and testing.",
      "item": [
        {
          "name": "DW Simple - JSON to JSON",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Purpose: Demonstrate simple JSON transformation and field normalization.\\n\\nUse when: Verifying simple DataWeave logic quickly.\\n\\ncURL:\\n\\ncurl --request POST '{{baseUrl}}/dw/simple' \\n--header 'Content-Type: application/json' \\n--data-raw '{\"Field1\":\"hello world\",\"phoneNumber\":\"555-123-4567\"}'",
            "body": {
              "mode": "raw",
